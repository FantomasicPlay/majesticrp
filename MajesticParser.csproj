<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- Установка иконки для собранного .exe файла -->
    <ApplicationIcon>icon.ico</ApplicationIcon>
    <AssemblyName>MajesticParser</AssemblyName>
    <Version>1.0.1</Version>
    <FileVersion>1.0.1.0</FileVersion>
    <Product>Majestic RP Parser</Product>
    <Authors>Fantomasic</Authors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AngleSharp" Version="1.5.1" />
    <PackageReference Include="Selenium.WebDriver" Version="4.45.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Включение иконки как ресурса для окон WPF -->
    <Resource Include="icon.ico" />
  </ItemGroup>

</Project>