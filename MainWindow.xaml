<Window x:Class="MajesticParser.MainWindow"
        x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MajesticParser"
        xmlns:vm="clr-namespace:MajesticParser.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Majestic RP Parser" Height="820" Width="1240"
        Icon="icon.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="#0E0E11">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <local:InverseBooleanConverter x:Key="InvBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ============ ПАЛИТРА MAJESTIC ============ -->
        <SolidColorBrush x:Key="Bg" Color="#0E0E11" />
        <SolidColorBrush x:Key="Panel" Color="#0A0A0C" />
        <SolidColorBrush x:Key="CardBg" Color="#17171B" />
        <SolidColorBrush x:Key="InputBg" Color="#202026" />
        <SolidColorBrush x:Key="Fg" Color="#F0F0F2" />
        <SolidColorBrush x:Key="Muted" Color="#8A8A92" />
        <SolidColorBrush x:Key="Accent" Color="#EC1E5B" />
        <SolidColorBrush x:Key="AccentHover" Color="#FF3D72" />
        <SolidColorBrush x:Key="Folder" Color="#F0A53C" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
        </Style>
        <Style TargetType="TextBlock" x:Key="Header">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="2,0,0,8" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="BorderBrush" Value="#2C2C33" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource Fg}" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <!-- Кнопка: плоская, со скруглением и hover -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Background" Value="#2A2A30" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinWidth" Value="70" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#37373F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#5A5A62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Главная (акцентная) кнопка -->
        <Style TargetType="Button" x:Key="AccentButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#5A2236" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопки заголовка окна -->
        <Style TargetType="Button" x:Key="CaptionButton">
            <Setter Property="Foreground" Value="#C7C7CC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#26262C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="CloseButton" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#E81123" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="BorderBrush" Value="#2C2C33" />
            <Setter Property="Height" Value="30" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{StaticResource InputBg}" BorderBrush="#2C2C33"
                                                BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="26" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#9AA0A6"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,28,0" VerticalAlignment="Center"
                                              TextElement.Foreground="{StaticResource Fg}" />

                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#17171B" BorderBrush="#2C2C33" BorderThickness="1"
                                        CornerRadius="6" Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="320">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#5A5A62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="#17171B" BorderBrush="Transparent"
                                BorderThickness="3,0,0,0" Padding="{TemplateBinding Padding}"
                                CornerRadius="4" Margin="2,1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- наведение -->
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#26262C" />
                            </Trigger>
                            <!-- выбранный пункт — тёмный с розовой полоской слева -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2A2A31" />
                                <Setter TargetName="b" Property="BorderBrush" Value="#EC1E5B" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="TreeView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#23232A" />
        </Style>

        <!-- Карточка без обводки -->
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="6" />
        </Style>

        <!-- ===== Узел дерева ===== -->
        <HierarchicalDataTemplate DataType="{x:Type vm:TreeNodeViewModel}" ItemsSource="{Binding Children}">
            <Border CornerRadius="4" Padding="2,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <!-- выделенный для удаления узел — розовая подсветка -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="#55EC1E5B" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          IsEnabled="{Binding CheckEnabled}"
                          Visibility="{Binding HasCheckbox, Converter={StaticResource BoolToVis}}"
                          ToolTip="{Binding CheckTooltip}"
                          VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBlock Text="{Binding Icon}" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="13" />
                <TextBlock Text="{Binding Display}" VerticalAlignment="Center" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#F0F0F2" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsForum}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="#F0A53C" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDimmed}" Value="True">
                                    <Setter Property="Foreground" Value="#5A5A62" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Placeholder">
                                    <Setter Property="Foreground" Value="#7A7A82" />
                                    <Setter Property="FontStyle" Value="Italic" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="  ⏳ загрузка…" Foreground="{StaticResource Muted}" FontStyle="Italic"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
            </Border>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Кастомный заголовок окна ===== -->
        <Grid Grid.Row="0" Background="{StaticResource Panel}" MouseDown="TitleBar_MouseDown">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                <TextBlock Text="⚖" FontSize="16" Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
                <TextBlock Text="Majestic RP Parser" FontWeight="Bold" FontSize="14"
                           Foreground="White" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" Content="—" />
                <Button Style="{StaticResource CaptionButton}" Click="MaxRestore_Click">
                    <TextBlock x:Name="MaxGlyph" Text="□" FontSize="14" />
                </Button>
                <Button Style="{StaticResource CloseButton}" Click="Close_Click" Content="✕" FontSize="14" />
            </StackPanel>
        </Grid>

        <!-- ===== Основная область ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="370" />
            </Grid.ColumnDefinitions>

            <!-- Дерево -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <!-- Выбор сервера → раздела -->
                    <Border DockPanel.Dock="Top" Background="#202026" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖥 Сервер:" VerticalAlignment="Center" FontWeight="SemiBold" Width="74" />
                                <ComboBox Width="240" ItemsSource="{Binding Servers}"
                                          SelectedItem="{Binding SelectedServer}" DisplayMemberPath="Name"
                                          VerticalAlignment="Center"
                                          ToolTip="Категория-сервер форума (например Majestic РП | New York)" />
                                <Button Content="Загрузить серверы" Command="{Binding LoadServersCommand}"
                                        Margin="8,0,0,0" MinWidth="0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="📂 Раздел:" VerticalAlignment="Center" FontWeight="SemiBold" Width="74" />
                                <ComboBox Width="240" ItemsSource="{Binding Sections}"
                                          SelectedItem="{Binding SelectedSection}" DisplayMemberPath="Name"
                                          VerticalAlignment="Center"
                                          ToolTip="Раздел выбранного сервера (Организации, Жалобы и заявления…)" />
                                <TextBlock Text="→ откроется в дереве" VerticalAlignment="Center"
                                           Foreground="{StaticResource Muted}" FontSize="11" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Действия с источниками -->
                    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Button Content="➕ Добавить раздел" Command="{Binding OpenAddSourceCommand}" MinWidth="0" />
                        <Button Content="🗑 Удалить источник" Command="{Binding OpenRemoveSourceCommand}" MinWidth="0" />
                        <Button Content="🔄 Обновить" Command="{Binding RefreshTreeCommand}" MinWidth="0"
                                ToolTip="Обновить дерево и вернуть всё удалённое" />
                        <Button Content="🗑 Удалить выделенные" Command="{Binding DeleteSelectedCommand}" MinWidth="0"
                                ToolTip="Удалить все выделенные узлы (выделять: Ctrl+клик или Shift+клик, либо клавиша Delete)" />
                        <Button Content="☐ Снять галочки" Command="{Binding UncheckAllCommand}" MinWidth="0" />
                        <Button Content="▾ Свернуть всё" Command="{Binding CollapseAllCommand}" MinWidth="0" />
                    </WrapPanel>

                    <!-- Легенда -->
                    <Border DockPanel.Dock="Top" Background="#1B1B20" CornerRadius="8" Padding="10,8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Foreground="#C2C2C8" TextWrapping="Wrap">
                                <Run Text="📁 Раздел" FontWeight="SemiBold" Foreground="#F0A53C" /><Run Text=" — папка, ▸ раскрывает подфорумы и темы." />
                            </TextBlock>
                            <TextBlock Foreground="#C2C2C8" TextWrapping="Wrap">
                                <Run Text="📄 Тема (закон)" FontWeight="SemiBold" /><Run Text=" — то, что парсится. " /><Run Text="☑ на 📁" FontWeight="SemiBold" /><Run Text=" = взять весь раздел." />
                            </TextBlock>
                            <TextBlock Foreground="#C2C2C8" TextWrapping="Wrap">
                                <Run Text="🗑 Правый клик" FontWeight="SemiBold" /><Run Text=" — удалить папку или тему из дерева." />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="Tree" ItemsSource="{Binding RootNodes}"
                              PreviewMouseLeftButtonDown="Tree_PreviewMouseLeftButtonDown"
                              KeyDown="Tree_KeyDown">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Foreground" Value="{StaticResource Fg}" />
                                <Setter Property="Padding" Value="1" />
                                <Setter Property="Tag"
                                        Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="🔄 Обновить из сети"
                                                      Command="{Binding PlacementTarget.Tag.RefreshNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="🗑 Удалить из дерева"
                                                      Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Настройки -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="ЧТО И КАК ПАРСИТЬ" Style="{StaticResource Header}" />

                    <TextBlock Text="Режим обработки:" FontSize="11" Foreground="{StaticResource Muted}" />
                    <ComboBox ItemsSource="{Binding ImageModes}" SelectedIndex="{Binding SelectedImageModeIndex}" />

                    <TextBlock Text="Post ID через запятую (режимы 4 и 6):" FontSize="11" Foreground="{StaticResource Muted}" Margin="0,8,0,0" />
                    <TextBox Text="{Binding PostIdsText, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding PostIdsEnabled}" />

                    <TextBlock Text="Авторы через запятую (режимы 5 и 7):" FontSize="11" Foreground="{StaticResource Muted}" Margin="0,8,0,0" />
                    <TextBox Text="{Binding AuthorsText, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding AuthorsEnabled}" />

                    <Separator Margin="0,12" />

                    <CheckBox Content="Headless (браузер скрыт)" IsChecked="{Binding Headless}" />

                    <TextBlock Text="Папка для результатов:" FontSize="11" Foreground="{StaticResource Muted}" Margin="0,10,0,0" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding OutputBaseDir}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Обзор…" Command="{Binding BrowseFolderCommand}"
                                MinWidth="0" Margin="6,0,0,0" />
                    </Grid>

                    <Separator Margin="0,12" />

                    <CheckBox Content="Возобновить незавершённый запуск" IsChecked="{Binding ResumeEnabled}" />
                    <ComboBox ItemsSource="{Binding ResumableRuns}" SelectedItem="{Binding SelectedResumeRun}"
                              IsEnabled="{Binding ResumeEnabled}" Margin="0,4,0,0" />

                    <Separator Margin="0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="▶ СТАРТ" Command="{Binding StartCommand}"
                                Style="{StaticResource AccentButton}" MinWidth="130" />
                        <Button Content="⏹ Стоп" Command="{Binding CancelCommand}" MinWidth="90" />
                    </StackPanel>
                    <TextBlock Text="Отметьте темы 📄 или разделы 📁 в дереве и нажмите Старт."
                               FontSize="11" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Лог ===== -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="ЛОГ" Style="{StaticResource Header}" />
                <TextBox x:Name="LogBox" Text="{Binding LogText, Mode=OneWay}"
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"
                         Background="#0B0B0D" Foreground="#C8C8CE" BorderThickness="0" />
            </DockPanel>
        </Border>

        <!-- ===== Статус ===== -->
        <Border Grid.Row="3" Background="{StaticResource Panel}" Padding="14,7">
            <Grid>
                <TextBlock Text="{Binding Status}" Foreground="#C2C2C8" VerticalAlignment="Center" />
                <ProgressBar Width="220" Height="6" HorizontalAlignment="Right"
                             Background="#1B1B20" Foreground="{StaticResource Accent}" BorderThickness="0"
                             IsIndeterminate="{Binding IsBusy}" />
            </Grid>
        </Border>

        <!-- ===== ВСПЛЫВАЮЩИЕ ОКНА ===== -->
        <Grid Grid.RowSpan="4" Background="#C0000000"
              Visibility="{Binding AnyOverlay, Converter={StaticResource BoolToVis}}">

            <!-- Добавить раздел -->
            <Border Width="520" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#17171B" CornerRadius="12" Padding="22"
                    Visibility="{Binding ShowAddSource, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Добавить раздел (папку)" FontSize="17" FontWeight="Bold" Foreground="{StaticResource Accent}" />
                    <TextBlock TextWrapping="Wrap" Foreground="#C2C2C8" Margin="0,6,0,12">
                        <Run Text="Добавлять можно только " /><Run Text="📁 разделы-форумы" FontWeight="SemiBold" Foreground="#F0A53C" /><Run Text=" — ссылки вида " /><Run Text="/forums/..." FontStyle="Italic" />
                    </TextBlock>

                    <TextBlock Text="URL раздела:" FontWeight="SemiBold" Margin="0,4,0,2" />
                    <TextBox Text="{Binding NewSourceUrl, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="{Binding NewSourceTypeLabel}" Foreground="#7FD49A" FontStyle="Italic" Margin="0,4,0,0" />

                    <TextBlock Text="Название (необязательно):" FontWeight="SemiBold" Margin="0,12,0,2" />
                    <TextBox Text="{Binding NewSourceName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="{Binding AddSourceError}" Foreground="#FF6B7B" TextWrapping="Wrap" Margin="0,8,0,0" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Добавить" Command="{Binding ConfirmAddSourceCommand}"
                                Style="{StaticResource AccentButton}" MinWidth="110" />
                        <Button Content="Отмена" Command="{Binding CloseOverlayCommand}" MinWidth="90" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Обновление -->
            <Border Width="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#17171B" CornerRadius="12" Padding="22"
                    Visibility="{Binding ShowUpdate, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="⬆ Доступно обновление" FontSize="17" FontWeight="Bold" Foreground="{StaticResource Accent}" />
                    <TextBlock Text="{Binding UpdateText}" TextWrapping="Wrap" Foreground="#C2C2C8" Margin="0,8,0,0" />
                    <TextBlock Text="{Binding UpdateStatus}" TextWrapping="Wrap" Foreground="#7FD49A" Margin="0,10,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Обновить сейчас" Command="{Binding UpdateNowCommand}"
                                Style="{StaticResource AccentButton}" MinWidth="150" />
                        <Button Content="Позже" Command="{Binding DismissUpdateCommand}" MinWidth="90" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Удалить источник -->
            <Border Width="580" Height="430" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#17171B" CornerRadius="12" Padding="22"
                    Visibility="{Binding ShowRemoveSource, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Удалить источник" FontSize="17" FontWeight="Bold" Foreground="{StaticResource Accent}" />
                    <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="#C2C2C8" Margin="0,6,0,12"
                               Text="Только добавленные вами источники. Стандартную «Законодательную базу» удалить нельзя." />

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="🗑 Удалить выбранный" Command="{Binding RemoveSelectedSourceCommand}"
                                Style="{StaticResource AccentButton}" MinWidth="160" />
                        <Button Content="Закрыть" Command="{Binding CloseOverlayCommand}" MinWidth="90" Margin="8,0,0,0" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding CustomSources}" SelectedItem="{Binding SelectedCustomSource}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Type}" FontSize="11" Foreground="White"
                                                   Background="#EC1E5B" Padding="6,1" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="6,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Url}" FontSize="10" Foreground="{StaticResource Muted}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
